      // ← Thêm folders cần ignore của bạn
    ],
    "extensions": [
      ".js",
      ".ts",
      ".jsx",
      ".tsx",
      ".py",
      ".go",
      ".rs"
      // ← Thêm/bớt extensions theo project
    ],
    "maxFileSize": 100000
  }
}
```

