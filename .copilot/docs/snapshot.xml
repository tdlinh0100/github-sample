      Array.from(allComponentScanPackages).forEach(pkg => {
        console.log(`  - ${pkg}`);
      });
    }

    return discovery;

  } catch (error) {
    spinner.fail(chalk.red('Spring XML discovery failed'));
    console.error(error);
    throw error;
  }
}

// Run if called directly
if (import.meta.url === pathToFileURL(process.argv[1]).href) {
  discoverSpringXmlProject();
}

